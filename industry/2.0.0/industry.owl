        <rdfs:comment xml:lang="en">This class represents an Area of a location.</rdfs:comment>
        <rdfs:label>Area</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#Department -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#Department">
