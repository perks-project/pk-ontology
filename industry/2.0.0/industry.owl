    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#Device -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#Device">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pko/industry#Machine"/>
        <rdfs:comment xml:lang="en">This class represents a Device.</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#EnergySource -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#EnergySource">
        <rdfs:comment xml:lang="en">This class represents an Energy Source, that is a source of energy on the machine that needs to be identified and isolated during the LOTO procedure.</rdfs:comment>
        <rdfs:label>Energy Source</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#Factory -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#Factory">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Location"/>
        <rdfs:comment xml:lang="en">This class represents a building or set of buildings with facilities for manufacturing.</rdfs:comment>
        <rdfs:label>Factory</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#Lock -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#Lock">
        <rdfs:comment xml:lang="en">This class represents a Lock, that is a device to be attached to the machine in order to prevent its re-activation, during the execution of a LOTO procedure.</rdfs:comment>
        <rdfs:label>Lock</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#Machine -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#Machine">
        <rdfs:comment xml:lang="en">This class represents a Machine.</rdfs:comment>
        <rdfs:label>Machine</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#MachineType -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#MachineType">
        <rdfs:comment xml:lang="en">This class represents the Type of a Machine.</rdfs:comment>
        <rdfs:label>Machine Type</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this class represents the Machine Type of a Machine.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#PersonalProtectiveEquipment -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#PersonalProtectiveEquipment">
        <rdfs:comment xml:lang="en">This class represents a Personal Protective Equipment.</rdfs:comment>
        <rdfs:label>Personal Protective Equipment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pko/industry#Site -->


    <owl:Class rdf:about="https://w3id.org/pko/industry#Site">
        <rdfs:comment xml:lang="en">This class represents a Site, that is a physical location or facility.</rdfs:comment>
        <rdfs:label>Site</rdfs:label>
    </owl:Class>
    


