    <!-- https://w3id.org/pko/industry#hasArea -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#hasArea">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Location"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#Area"/>
        <rdfs:comment xml:lang="en">This property is used to link a Location to an Area within it.</rdfs:comment>
        <rdfs:label>has area</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Location to an Area within it.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#hasDepartment -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#hasDepartment">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Location"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#Department"/>
        <rdfs:comment xml:lang="en">This property is used to link a Location to a Department within it.</rdfs:comment>
        <rdfs:label>has department</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Location to a Department within it.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#hasMachineType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#hasMachineType">
        <rdfs:domain rdf:resource="https://w3id.org/pko/industry#Machine"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#MachineType"/>
        <rdfs:comment xml:lang="en">This property is used to link a Machine to its Machine Type.</rdfs:comment>
        <rdfs:label>has machine type</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Machine to the Machine Type.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#hasSite -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#hasSite">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Location"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#Site"/>
        <rdfs:comment xml:lang="en">This property is used to link a Location to a Site.</rdfs:comment>
        <rdfs:label>has site</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Location to a Site.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#isExecutedOnMachine -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#isExecutedOnMachine">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#Machine"/>
        <rdfs:comment xml:lang="en">This property is used to link an Activity (e.g., a Step Execution) to the Machine it is executed on.</rdfs:comment>
        <rdfs:label>is executed on machine</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Activity (e.g., a Step Execution) to the Machine it is executed on.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#requiresLock -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#requiresLock">
        <rdfs:domain rdf:resource="http://purl.org/net/p-plan#Step"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#Lock"/>
        <rdfs:comment xml:lang="en">This property is used to link a Step to the Lock it requires.</rdfs:comment>
        <rdfs:label>requires lock</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Lock it requires.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#requiresPPE -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#requiresPPE">
        <rdfs:domain rdf:resource="http://purl.org/net/p-plan#Step"/>
        <rdfs:range rdf:resource="https://w3id.org/pko/industry#PersonalProtectiveEquipment"/>
        <rdfs:comment xml:lang="en">This property is used to link a Step to the Personal Protective Equipment (PPE) that is required by the Step.</rdfs:comment>
        <rdfs:label>requires p p e</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Personal Protective Equipment (PPE) that is required by the Step.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko/industry#wasManufacturedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pko/industry#wasManufacturedBy">
        <rdfs:domain rdf:resource="https://w3id.org/pko/industry#Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment xml:lang="en">This property is used to link a Machine to the Agent that manufactured it.</rdfs:comment>
        <rdfs:label>was manufactured by</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Machine to the Agent that manufactured it.</skos:scopeNote>
    </owl:ObjectProperty>
    


