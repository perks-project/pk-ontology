    rdfs:label "Procedure Execution" ;
    rdfs:subClassOf prov:Activity .

pko:ProcedureExecutionStatus a owl:Class ;
    rdfs:label "Procedure Execution Status" ;
    rdfs:subClassOf pko:Status .

pko:Status a owl:Class ;
    rdfs:label "Status" .

pko:UserFeedbackOccurrence a owl:Class ;
    rdfs:label "User Feedback Occurrence" ;
    rdfs:subClassOf prov:InstantaneousEvent .

pko:UserQuestionOccurrence a owl:Class ;
    rdfs:label "User Question Occurrence" ;
    rdfs:subClassOf prov:InstantaneousEvent .

pko:ExpertiseLevel a owl:Class ;
    rdfs:label "Expertise Level" .

pko:IssueOccurrence a owl:Class ;
    rdfs:label "Issue Occurrence" ;
    rdfs:subClassOf prov:InstantaneousEvent .

pko:RequirementSatisfactionLevel a owl:Class ;
    rdfs:label "Requirement Satisfaction Level" .

dcat:Resource a owl:Class ;
    rdfs:label "Resource" .

prov:Agent a owl:Class ;
    rdfs:label "Agent" .

pko:ProcedureStatus a owl:Class ;
    rdfs:label "Procedure Status" ;
    rdfs:subClassOf pko:Status .

pko:StepExecution a owl:Class ;
    rdfs:label "Step Execution" ;
    rdfs:subClassOf prov:Activity .

prov:Activity a owl:Class ;
    rdfs:label "Activity" .

pko:Procedure a owl:Class ;
    rdfs:label "Procedure" ;
    rdfs:subClassOf pplan:Plan,
        dcat:Resource .

pplan:Step a owl:Class ;
    rdfs:label "Step" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/dcam/domainIncludes
dcam:domainIncludes rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/dcam/rangeIncludes
dcam:rangeIncludes rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .

#################################################################
#    Metadata
#################################################################

<https://orcid.org/0000-0003-1427-3723> a foaf:Person ;
        foaf:name "Valentina Anita Carriero"@en .
<https://orcid.org/0000-0002-8235-7331> a foaf:Person ;
        foaf:name "Mario Scrocca"@en .
<https://orcid.org/0000-0001-5791-8427> a foaf:Person ;
        foaf:name "Ilaria Baroni"@en .
<https://orcid.org/0000-0002-9066-1229> a foaf:Person ;
        foaf:name "Antonia Azzini"@en .
<https://orcid.org/0000-0001-9962-7193> a foaf:Person ;
        foaf:name "Irene Celino"@en .

<https://ror.org/046bfkz44> a foaf:Organization ;
        foaf:name "Cefriel"@en .

#################################################################
#    Object Properties
#################################################################

###  http://purl.org/net/p-plan#isStepOfPlan
<http://purl.org/net/p-plan#isStepOfPlan> owl:inverseOf pko:hasStep ;
                                          dcam:domainIncludes <http://purl.org/net/p-plan#Step> ,
                                                              pko:Procedure ;
                                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Procedure it is a step of."@en .


###  http://www.w3.org/ns/dcat#hasCurrentVersion
<http://www.w3.org/ns/dcat#hasCurrentVersion> owl:inverseOf pko:isCurrentVersionOf ;
                                              dcam:domainIncludes pko:Procedure ;
                                              dcam:rangeIncludes pko:Procedure ;
                                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure, for which we want to manage version control, to its current version."@en .


###  http://www.w3.org/ns/dcat#previousVersion
<http://www.w3.org/ns/dcat#previousVersion> owl:inverseOf pko:nextVersion ;
                                            dcam:domainIncludes pko:Procedure ;
                                            dcam:rangeIncludes pko:Procedure ;
                                            skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a version of a Procedure to its direct previous version of the same Procedure."@en .


###  http://www.w3.org/ns/prov#wasAssociatedWith
<http://www.w3.org/ns/prov#wasAssociatedWith> dcam:domainIncludes <http://www.w3.org/ns/prov#Activity> ;
                                              dcam:rangeIncludes <http://www.w3.org/ns/prov#Agent> ;
                                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Activity (either a Procedure Execution or a Step Execution) to an Agent that had some role/responsibility in that Activity."@en .


###  https://w3id.org/pko#hasStep
pko:hasStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its Steps."@en ;
            skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its Steps."@en .


###  https://w3id.org/pko#hasStepVerification
pko:hasStepVerification owl:inverseOf pko:isStepVerificationOf ;
                        rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step of a Procedure to a Step Verification, that is the way in which the execution of the step can be verified."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step of a Procedure to a Step Verification, that is the way in which the execution of the step can be verified."@en .


###  https://w3id.org/pko#includesStepExecution
pko:includesStepExecution owl:inverseOf pko:isIncludedInProcedureExecution ;
                          rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution to a Step Execution, that is the execution of one of the Steps of the Procedure."@en ;
                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution to a Step Execution, that is the execution of one of the Steps of the Procedure."@en .


###  https://w3id.org/pko#isIncludedInProcedureExecution
pko:isIncludedInProcedureExecution rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to a Procedure Execution, that is the execution of the whole Procedure the Step is part of."@en ;
                                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to a Procedure Execution, that is the execution of the whole Procedure the Step is part of."@en .


###  https://w3id.org/pko#isStepVerificationOf
pko:isStepVerificationOf rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Verification, that is the way in which the execution of the step can be verified, to the Step it verifies."@en ;
                         skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Verification, that is the way in which the execution of the step can be verified, to the Step it verifies."@en .


###  https://w3id.org/pko#nextStep
pko:nextStep owl:inverseOf pko:previousStep ;
             rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct next Step. If a Step is linked to multiple Steps with this property, it means that such next steps can be executed regardless of their order."@en ;
             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct next Step. If a Step is linked to multiple Steps with this property, it means that such next steps can be executed regardless of their order."@en .


###  https://w3id.org/pko#nextStepExecution
pko:nextStepExecution owl:inverseOf pko:previousStepExecution ;
                      rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to its direct next Step Execution."@en ;
                      skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to its direct next Step Execution."@en .


###  https://w3id.org/pko#nextVersion
pko:nextVersion rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a version of a Procedure to its direct next version of the same Procedure."@en ;
                skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a version of a Procedure to its direct next version of the same Procedure."@en .


###  https://w3id.org/pko#previousStep
pko:previousStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct previous Step."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct previous Step."@en .


###  https://w3id.org/pko#previousStepExecution
pko:previousStepExecution rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to its direct previous Step Execution."@en ;
                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to its direct previous Step Execution."@en .


###  https://w3id.org/pko#wasConfirmedBy
pko:wasConfirmedBy rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAssociatedWith> ;
                   rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Activity (e.g., a Step Execution) to the Agent that confirmed the Activity."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Activity (e.g., a Step Execution) to the Agent that confirmed the Activity."@en .


###  https://w3id.org/pko#wasExecutedBy
pko:wasExecutedBy rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAssociatedWith> ;
                  rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Activity (e.g., a Step Execution) to the Agent that executed the Activity."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Activity (e.g., a Step Execution) to the Agent that executed the Activity."@en .


#################################################################
#    Annotations
#################################################################

<http://purl.org/dc/terms/created> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                   dcam:rangeIncludes xsd:dateTime ;
                                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the creation dateTime of a Resource (e.g., a Procedure)."@en .


<http://purl.org/dc/terms/creator> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                   dcam:rangeIncludes <http://www.w3.org/ns/prov#Agent> ;
                                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure) to the Agent that created it."@en .


<http://purl.org/dc/terms/description> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ,
                                                           <http://www.w3.org/ns/prov#Activity> ;
                                       dcam:rangeIncludes xsd:string ;
                                       skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent a description of an entity, including: a Procedure, a Step, a Procedure Execution, a Step Execution, a Step Verification, a Resource that is referenced by or which a Procedure was extracted from."@en .


<http://purl.org/dc/terms/format> dcam:domainIncludes <http://purl.org/dc/terms/MediaTypeOrExtent> ,
                                                      <http://www.w3.org/ns/dcat#Resource> ;
                                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure or a Resource referenced by a Procedure), to the Media Type or Extent of the resource."@en .


<http://purl.org/dc/terms/identifier> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                      dcam:rangeIncludes xsd:string ;
                                      skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the identifier of an entity, including: a Procedure, a Step, a Procedure Execution, a Step Execution, a Step Verification, a FAQ Category, a FAQ Target, a Resource that is referenced by or which a Procedure was extracted from."@en .


<http://purl.org/dc/terms/language> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                    dcam:rangeIncludes xsd:string ;
                                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the language of a Resource (e.g., a Procedure)."@en .


<http://purl.org/dc/terms/modified> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                    dcam:rangeIncludes xsd:dateTime ;
                                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the dateTime when a Resource  (e.g., a Procedure) has been modified."@en .


<http://purl.org/dc/terms/references> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                      dcam:rangeIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                      skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure) to another Resource (e.g., a document, an image, or another Procedure) that the Procedure references."@en .


<http://purl.org/dc/terms/temporal> dcam:domainIncludes <http://purl.org/spar/pro/RoleInTime> ;
                                    dcam:rangeIncludes <http://purl.org/dc/terms/PeriodOfTime> ;
                                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Role In Time held by an Agent to the Period of Time in which that Role is valid."@en .


<http://purl.org/dc/terms/title> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                 dcam:rangeIncludes xsd:string ;
                                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the name/title of an entity, including: a Procedure, a Step, a Procedure Execution, a Step Execution, a Step Verification, a FAQ Category, a FAQ Target, a Resource that is referenced by or which a Procedure was extracted from."@en .


<http://purl.org/net/p-plan#correspondsToVariable> dcam:domainIncludes <http://www.w3.org/ns/prov#Entity> ;
                                                   dcam:rangeIncludes <http://purl.org/net/p-plan#Variable> ;
                                                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Entity used by an Activity (either a Procedure Execution or a Step Execution) to the Variable it represented in the Procedure."@en .


<http://purl.org/net/p-plan#hasInputVar> dcam:domainIncludes <http://purl.org/net/p-plan#Step> ;
                                         dcam:rangeIncludes <http://purl.org/net/p-plan#Variable> ;
                                         skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Variable that the Step needs to take as input for the Step Execution."@en .


<http://purl.org/net/p-plan#hasOutputVar> dcam:domainIncludes <http://purl.org/net/p-plan#Step> ;
                                          dcam:rangeIncludes <http://purl.org/net/p-plan#Variable> ;
                                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Variable that the Step needs to produce as output of the Step Execution."@en .


<http://purl.org/spar/pro/holdsRoleInTime> dcam:domainIncludes <http://www.w3.org/ns/prov#Agent> ;
                                           dcam:rangeIncludes <http://purl.org/spar/pro/RoleInTime> ;
                                           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Agent to the Role In Time, that is the role that the Agent holds for a certain Period of Time."@en .


<http://purl.org/spar/pro/relatesTo> dcam:domainIncludes <http://purl.org/spar/pro/RoleInTime> ;
                                     dcam:rangeIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Role In Time, that is the role that an Agent holds for a certain Period of Time, to the Resource (e.g., a Procedure) that the Role relates to."@en .


<http://purl.org/spar/pro/withRole> dcam:domainIncludes <http://purl.org/spar/pro/RoleInTime> ;
                                    dcam:rangeIncludes <http://purl.org/spar/pro/Role> ;
                                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Role In Time, that is the role that an Agent holds for a certain Period of Time, to the Role that is held."@en .


<http://w3id.org/nfdi4ing/metadata4ing#Tool> skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents an object needed to execute a Step of a Procedure."@en .


<http://www.w3.org/2006/time#numericDuration> dcam:domainIncludes <http://www.w3.org/2006/time#Duration> ;
                                              dcam:rangeIncludes xsd:date ;
                                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the value of a temporal extent expressed as a number scaled by a temporal unit (in the form of xsd:decimal)."@en .


<http://www.w3.org/2006/time#unitType> dcam:domainIncludes <http://www.w3.org/2006/time#Duration> ;
                                       dcam:rangeIncludes <http://www.w3.org/2006/time#TemporalUnit> ;
                                       skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Duration of time to the Temporal Unit which provides the precision of a date-time value or scale of a temporal extent."@en .


<http://www.w3.org/ns/adms#status> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                   dcam:rangeIncludes pko:ProcedureStatus , pko:ProcedureExecutionStatus , pko:EvaluationRequestStatus ;
                                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link either a Procedure or a Procedure Execution to its Status."@en .


<http://www.w3.org/ns/dcat#endDate> dcam:domainIncludes <http://purl.org/dc/terms/PeriodOfTime> ;
                                    dcam:rangeIncludes xsd:date ;
                                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the end of a Period Of Time."@en .


<http://www.w3.org/ns/dcat#hasVersion> dcam:domainIncludes pko:Procedure ;
                                       dcam:rangeIncludes pko:Procedure ;
                                       skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure, for which we want to manage version control, to one of its versions."@en .


<http://www.w3.org/ns/dcat#isVersionOf> dcam:domainIncludes pko:Procedure ;
                                        dcam:rangeIncludes pko:Procedure ;
                                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to a version of a procedure to the Procedure, for which we want to manage version control."@en .


<http://www.w3.org/ns/dcat#keyword> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                                    dcam:rangeIncludes xsd:string ;
                                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent a keyword or tag describing a Resource (e.g, a Procedure)."@en .


<http://www.w3.org/ns/dcat#startDate> dcam:domainIncludes <http://purl.org/dc/terms/PeriodOfTime> ;
                                      dcam:rangeIncludes xsd:date ;
                                      skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the start of a Period Of Time."@en .


<http://www.w3.org/ns/prov#atTime> dcam:domainIncludes <http://www.w3.org/ns/prov#InstantaneousEvent> ;
                                   dcam:rangeIncludes xsd:dateTime ;
                                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the dateTime at which an InstantaneousEvent occurred."@en .


<http://www.w3.org/ns/prov#endedAtTime> dcam:domainIncludes <http://www.w3.org/ns/prov#Activity> ;
                                        dcam:rangeIncludes xsd:dateTime ;
                                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the dateTime at which an activity ended."@en .


<http://www.w3.org/ns/prov#startedAtTime> dcam:domainIncludes <http://www.w3.org/ns/prov#Activity> ;
                                          dcam:rangeIncludes xsd:dateTime ;
                                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the dateTime at which an activity started."@en .


<http://www.w3.org/ns/prov#used> dcam:domainIncludes pko:StepExecution ;
                                 dcam:rangeIncludes <http://www.w3.org/ns/prov#Entity> ;
                                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to an Entity that is being used during execution, and that may correspond to an input Variable of the Step."@en .


<http://www.w3.org/ns/prov#wasGeneratedBy> dcam:domainIncludes <http://www.w3.org/ns/prov#Entity> ;
                                           dcam:rangeIncludes pko:StepExecution ;
                                           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to an Entity that was generated during execution, and that may correspond to an output Variable of the Step."@en .


<http://www.w3.org/ns/odrl/2/hasPolicy> dcam:domainIncludes pko:Procedure , pko:ProcedureType ;
                                        dcam:rangeIncludes <http://www.w3.org/ns/odrl/2/Policy> ;
                                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to an ODRL policy governing permissions such as manage/read/modify/execute."@en .


<https://schema.org/url> dcam:domainIncludes <http://www.w3.org/ns/dcat#Resource> ;
                         dcam:rangeIncludes xsd:string ;
                         skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the URL associated with a Resource."@en .


<https://w3id.org/force/sotw#evaluatedAction> dcam:domainIncludes <https://w3id.org/force/sotw#EvaluationRequest> ;
                                              dcam:rangeIncludes <http://www.w3.org/ns/odrl/2/Action> ;
                                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an evaluation request to the action being evaluated."@en .


<https://w3id.org/force/sotw#evaluatedTarget> dcam:domainIncludes <https://w3id.org/force/sotw#EvaluationRequest> ;
                                              dcam:rangeIncludes pko:Procedure , pko:ProcedureType ;
                                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an evaluation request to the target resource for which the action is evaluated, e.g. a Procedure or a Procedure Type."@en .


pko:Action rdfs:comment "This class represents an Action performed by a human Agent."@en ;
           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents an action that needs to be performed by a human Agent (a Person) for executing a Step of a Procedure."@en .


pko:Error rdfs:comment "This class represents an Error that can be encountered while executing an activity."@en ;
          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents an error that an Agent can encounter during a Procedure or Step Execution. An Error can be associated with a description, an error code, and an error cause. The Procedure may contain a (fallback) step to address such error."@en .


pko:ExpertiseLevel rdfs:comment "This class represents the Expertise Level of an Agent with respect to certain activities/responsibilities."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the expertise level linked to a Step, or MultiStep, of a Procedure, meaning that the Step, or MultiStep, is targeted at persons with a certain level of expertise (e.g., junior, senior)."@en .


pko:FAQCategory rdfs:comment "This class represents the Category of a Frequently Asked Question (FAQ)."@en .


pko:FAQTarget rdfs:comment "This class represents the Target of a Frequently Asked Question (FAQ)."@en .


pko:FrequentlyAskedQuestion rdfs:comment "A Frequently Asked Question (FAQ) is a Resource representing a question that people often ask about a particular resource, and the answer to the question."@en ;
                            skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a Frequently Asked Question (FAQ) of a Procedure, and is described with an identifier, a question, an answer, and is linked to a FAQ Category and a FAQ Target."@en .


pko:Function rdfs:comment "This class represents a Function performed by a Software Agent."@en ;
             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a function that needs to be performed by a Software Agent for executing a Step of a Procedure."@en .


pko:IssueOccurrence rdfs:comment "This class represents the occurrence of an issue during an Activity."@en ;
                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the occurrence of an issue during the Procedure or Step Execution. The Issue Occurrence is associated with the cause as identified and defined by the Agent, the solution as identified and applied by the Agent, and is linked to the Agent that encountered the issue."@en .


pko:Procedure rdfs:comment "A Procedure represents a sequence of actions to be executed in order to achieve a desired outcome."@en .


pko:ProcedureExecution rdfs:comment "A Procedure Execution is an Activity representing the execution of a certain Procedure, performed by one or more Agents, during a time interval."@en .


pko:ProcedureExecutionStatus rdfs:comment "This class represents the Status of the Procedure Execution (e.g., in progress, completed, paused, cancelled)."@en ;
                             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), a Procedure Execution is linked to its Procedure Execution Status with the property adms:status."@en .


pko:ProcedureStatus rdfs:comment "This class represents the Status of the Procedure (e.g.,draft, validated)."@en ;
                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), a Procedure  is linked to its Procedure Status with the property adms:status."@en .


pko:ProcedureType rdfs:comment "This class represents the Type of a Procedure."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), an example of Procedure Type is LOTO Procedure."@en .


pko:StepExecution rdfs:comment "A Procedure Execution is an Activity representing the execution of a certain Step of a Procedure, performed by one or more Agents, during a time interval."@en .


pko:StepVerification rdfs:comment "A Step Verification is a description of the way in which the execution of a Step can be verified."@en .


pko:UserFeedbackOccurrence rdfs:comment "This class represents the occurrence of a feedback that was provided by a user during an activity."@en ;
                           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the occurrence of a feedback provided by an Agent during the Procedure or Step Execution. The User Feedback Occurrence is associated with the feedback, that is about either the Procedure or the Procedure Execution, and is linked to the Agent providing the feedback."@en .


pko:UserQuestionOccurrence rdfs:comment "This class represents the occurrence of a question that an Agent came up with during the Procedure or Step Execution."@en ;
                           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the occurrence of a question that an Agent came up with during the Procedure or Step Execution. The User Question Occurrence is associated with the question, and is linked to the Agent asking the question. Also, it can be linked to a Resource addressing the question."@en .


pko:addressesError rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a (Multi)Step of a Procedure to the Error it addresses. Such (Multi)Step represents a Fallback procedure."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a (Multi)Step of a Procedure to the Error it addresses. Such (Multi)Step represents a Fallback procedure."@en .


pko:answer rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the answer of a Frequently Asked Question."@en ;
           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the answer of a Frequently Asked Question."@en .


pko:changelogDescription rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the changelog description of a Procedure, that details all updates with respect to the previous version of the same Procedure."@en ;
                         skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the changelog description of a Procedure, that details all updates with respect to the previous version of the same Procedure."@en .


pko:errorCause rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the cause of an Error that can be encountered during the Procedure or Step Execution."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the cause of an Error that can be encountered during the Procedure or Step Execution."@en .


pko:errorCode rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the code of an Error that can be encountered during the Procedure or Step Execution."@en ;
              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the code of an Error that can be encountered during the Procedure or Step Execution."@en .


pko:hasExecutedProcedure rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution to the Procedure that is being executed."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution to the Procedure that is being executed."@en .


pko:hasExecutedStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to the Step that is being executed."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step Execution to the Step that is being executed."@en .


pko:feedbackOnProcedure rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the feedback on the procedure that was provided by an Agent during the Procedure or Step Execution."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the feedback on the procedure that was provided by an Agent during the Procedure or Step Execution."@en .


pko:feedbackOnProcedureExecution rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the feedback on the procedure execution that was provided by an Agent during the Procedure or Step Execution."@en ;
                                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the feedback on the procedure execution that was provided by an Agent during the Procedure or Step Execution."@en .


pko:hasEncounteredError rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link the Occurrence of an Issue to the Error that is being encountered by the Agent executing a Procedure or Step."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link the Occurrence of an Issue to the Error that is being encountered by the Agent executing a Procedure or Step."@en .


pko:hasExpectedDuration rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link the Occurrence of an Issue to the Error that is being encountered by the Agent executing a Procedure or Step."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link either a Procedure or a Step to the Duration that is expected for the execution of that Procedure/Step."@en .


pko:hasFAQCategory rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Frequently Asked Question to a Category it belongs to."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Frequently Asked Question to a Category it belongs to."@en .


pko:hasFAQTarget rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Frequently Asked Question to the Target of such FAQ."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Frequently Asked Question to the Target of such FAQ."@en .


pko:hasFallbackStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to a (Multi)Step that represents a Fallback procedure for a specific Error that can be encountered during execution."@en ;
                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to a (Multi)Step that represents a Fallback procedure for a specific Error that can be encountered during execution."@en .


pko:hasFirstStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its first Step."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its first Step."@en .


pko:hasIssueOccurrence rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution or Step Execution to an Issue Occurrence, that is the occurrence of an issue during the execution."@en ;
                       skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution or Step Execution to an Issue Occurrence, that is the occurrence of an issue during the execution."@en .


pko:hasProcedureTarget rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to its Procedure Target(s), that is the object at which the actions of the Procedure are directed. A Procedure Target can be, for instance: a Machine, an Equipment, a Workstation."@en ;
                       skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to its Procedure Target(s), that is the object at which the actions of the Procedure are directed. A Procedure Target can be, for instance: a Machine, an Equipment, a Workstation."@en .


pko:hasProcedureType rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to its Procedure Type (e.g., a LOTO Procedure)."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to its Procedure Type (e.g., a LOTO Procedure)."@en .


pko:hasUserFeedbackOccurrence rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution to a User Feedback Occurrence, that is the occurrence of a feedback that the user provides during execution about wither the Procedure or the Procedure Execution."@en ;
                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution to a User Feedback Occurrence, that is the occurrence of a feedback that the user provides during execution about wither the Procedure or the Procedure Execution."@en .


pko:hasUserQuestionOccurrence rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution or Step Execution to a User Question Occurrence, that is the occurrence of a question that the user came up with during execution."@en ;
                              skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution or Step Execution to a User Question Occurrence, that is the occurrence of a question that the user came up with during execution."@en .


pko:isAdoptedBy rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to an Organization which the Procedure is adopted by."@en ;
                skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure to an Organization which the Procedure is adopted by."@en .


pko:isQuestionAddressedBy rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a User Question Occurrence to a Resource that addresses/answers to the question that the user came up with during the Procedure/Step Execution."@en ;
                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a User Question Occurrence to a Resource that addresses/answers to the question that the user came up with during the Procedure/Step Execution."@en .


pko:isStepForExpertiseLevel rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Expertise Level, meaning that the Step, or MultiStep, is targeted at persons with a certain level of expertise (e.g., junior, senior)."@en ;
                            skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the Expertise Level, meaning that the Step, or MultiStep, is targeted at persons with a certain level of expertise (e.g., junior, senior)."@en .


pko:isStepOfMultiStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the MultiStep it is a step of."@en ;
                      skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to the MultiStep it is a step of."@en .


pko:isTemplate rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent whether a Procedure is a Template or not. A Procedure is a Template if it is associated with a preset of Steps that can be used to define an Executable Procedure. Such steps are not directly executable in the form they are specified."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent whether a Procedure is a Template or not. A Procedure is a Template if it is associated with a preset of Steps that can be used to define an Executable Procedure. Such steps are not directly executable in the form they are specified."@en .


pko:maxRepetitions rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the maximum number of repetitions for a Step. If the maxRepetitions is equal to 1, it means that the Step is not repeatable."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the maximum number of repetitions for a Step. If the maxRepetitions is equal to 1, it means that the Step is not repeatable."@en .


pko:minRepetitions rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the maximum number of repetitions for a Step. If the minRepetitions is equal to 1, it means that the Step is mandatory. If the minRepetitions is equal to 0, it means that the Step is optional."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the maximum number of repetitions for a Step. If the minRepetitions is equal to 1, it means that the Step is mandatory. If the minRepetitions is equal to 0, it means that the Step is optional."@en .


pko:newVersionMotivation rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the motivation for creating a new version of a Procedure, for which we want to manage version control."@en ;
                         skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the motivation for creating a new version of a Procedure, for which we want to manage version control."@en .


pko:nextAlternativeStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to at least two alternative Steps, if only one of such steps should be executed."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to at least two alternative Steps, if only one of such steps should be executed."@en .


pko:question rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the question of a Frequently Asked Question."@en ;
             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the question of a Frequently Asked Question."@en .


pko:questionByUser rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the question that a user came up with during the Procedure/Step Execution (User Question Occurrence)."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the question that a user came up with during the Procedure/Step Execution (User Question Occurrence)."@en .


pko:requiresAction rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to an Action that needs to be performed by a human Agent (a Person) for executing the Step."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to an Action that needs to be performed by a human Agent (a Person) for executing the Step."@en .


pko:requiresFunction rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to a Function that needs to be performed by a Software Agent for executing the Step."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to a Function that needs to be performed by a Software Agent for executing the Step."@en .


pko:requiresTool rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step of a Procedure to a Tool required by the Step, that is an object needed to execute the Step."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step of a Procedure to a Tool required by the Step, that is an object needed to execute the Step."@en .


pko:versionNumber rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the number of the version of a Procedure, for which we want to manage version control."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the number of the version of a Procedure, for which we want to manage version control."@en .


pko:wasAskedBy rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a User Question Occurrence to the Agent that asked the question during the Procedure/Step Execution."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a User Question Occurrence to the Agent that asked the question during the Procedure/Step Execution."@en .


pko:wasEncounteredBy rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Issue Occurrence to the Agent that encountered the issue during the Procedure/Step Execution."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an Issue Occurrence to the Agent that encountered the issue during the Procedure/Step Execution."@en .


pko:wasExtractedFrom rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure) to the Resource it was extracted from."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure) to the Resource it was extracted from."@en .


pko:wasModifiedBy rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure) to the Agent that modified the Resource."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Resource (e.g., a Procedure) to the Agent that modified the Resource."@en .


pko:wasProvidedBy rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a User Feedback Occurrence to the Agent that provided the feedback about either the procedure or the procedure execution during the Procedure Execution."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a User Feedback Occurrence to the Agent that provided the feedback about either the procedure or the procedure execution during the Procedure Execution."@en .


pko:ChangeOfStatus rdfs:comment "This class represents a change from one Status to another Status."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a change from one Status to another Status, e.g., a change of status of procedures or procedure executions."@en .


pko:EvaluationRequestStatus rdfs:comment "This class represents the Status of an Evaluation Request."@en ;
                skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the Status of an Evaluation Request, e.g., the evaluation of a request to modify a procedure is pending."@en .


pko:Explanation rdfs:comment "This class represents an explanation that clarifies something and why something can happen/happened."@en ;
                skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents an explanation that clarifies something and why something can happen/happened. It can be associated with procedural knowledge entities, such as transitions between steps and step executions."@en .


pko:Qualification rdfs:comment "This class represents a qualification of an agent."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a qualification of an agent; such qualification can represent a requirement to be satisfied in order for a procedure/step to be executed by that agent."@en .


pko:Requirement rdfs:comment "This class represents a requirement that must/can be satisfied."@en ;
                skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a requirement to be satisfied in order for a procedure/step to be executed."@en .


pko:RequirementSatisfaction rdfs:comment "This class represents the assessment of whether a requirement is satisfied during an execution."@en ;
                            skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents an activity that captures the satisfaction status of requirements in a Procedure Execution or Step Execution."@en .


pko:RequirementSatisfactionLevel rdfs:comment "This class represents the level of satisfaction of a requirement."@en ;
                                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the level of satisfaction of a requirement, such as partially satisfied or not evaluated."@en .


pko:RequirementType rdfs:comment "This class represents the type of a requirement."@en ;
                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the type of a requirement."@en .


pko:SignalVerification rdfs:comment "This class represents a signal-based verification associated with the execution of a Step."@en ;
                      skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a signal-based verification associated with the execution of a Step, as a specific type of Step Verification, which is a Step itself."@en .


pko:Status rdfs:comment "This class represents the status of an entity or an activity."@en ;
           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents the status of an entity, e.g. a procedure, or an activity, e.g., an evaluation request."@en .


pko:Transition rdfs:comment "This class represents a transition between two Steps."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this class represents a transition between two Steps, supporting the representation of explanations and requirements motivating the transition from a source step to a target step."@en .


pko:assigneeRole rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to associate a policy rule with the role of the assignee for that rule."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to associate a policy rule with the role of the assignee for that rule, in the context of access control."@en .


pko:expectedSignalValue rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the expected value of a signal in a Signal Verification."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used represent the expected value of a signal in a Signal Verification."@en .


pko:fromStatus rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the starting status of a Change Of Status."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the starting status of a Change Of Status."@en .


pko:fromStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the source step of a transition between steps."@en ;
             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the source step of a transition between steps."@en .


pko:hasChangeOfStatus rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an entity to the Change Of Status activities associated with it."@en ;
                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an entity to the Change Of Status activities associated with it."@en .


pko:hasExplanation rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a transition or step execution to an explanation."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a transition or step execution to an explanation."@en .


pko:hasRequirement rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure, a Step, or a Transition to its Requirements."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure, a Step, or a Transition to its Requirements."@en .


pko:hasRequirementSatisfaction rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution or Step Execution to a Requirement Satisfaction."@en ;
                             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure Execution or Step Execution to a Requirement Satisfaction."@en .


pko:hasRequirementSatisfactionLevel rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement Satisfaction to its satisfaction level."@en ;
                                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement Satisfaction to its satisfaction level (satisfied, partially satisfied, not satisfied, not evaluated)."@en .


pko:hasRequirementType rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement to its Requirement Type."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement to its Requirement Type, e.g., recommended or mandatory."@en .


pko:hasTemplate rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure that can be actually executed to its Template Procedure."@en ;
                skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure that can be actually executed to its Template Procedure."@en .


pko:isChangeOfStatusOf rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Change Of Status to the entity whose status changed."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Change Of Status to the entity whose status changed."@en .


pko:isCurrentVersionOf rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure version to the Procedure it is the current version of."@en ;
                    skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure version to the Procedure it is the current version of."@en .


pko:isFirstStepOf rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to a Procedure or MultiStep for which it is the first step."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to a Procedure or MultiStep for which it is the first step."@en .


pko:isTemplateOf rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Template Procedure to procedures based on that template."@en ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Template Procedure to procedures based on that template."@en .


pko:issueCause rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the cause of an issue encountered during a Procedure or Step Execution."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the cause of an issue encountered during a Procedure or Step Execution."@en .


pko:issueSolution rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the solution of an issue encountered during a Procedure or Step Execution."@en ;
                  skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the solution of an issue encountered during a Procedure or Step Execution."@en .


pko:previousAlternativeStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to an a previous alternative step."@en ;
                        skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to an a previous alternative step."@en .


pko:refersToRequirement rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement Satisfaction to the Requirement it evaluates."@en ;
                       skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement Satisfaction to the Requirement it evaluates."@en .


pko:requestStatusMotivation rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the motivation associated with the status of an access or evaluation request."@en ;
                          skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the motivation associated with the status of an access or evaluation request."@en .


pko:requiredEntity rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement to the entity that is required."@en ;
                   skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Requirement to the entity that is required."@en .


pko:signalIdentifier rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the identifier of a signal in a Signal Verification."@en ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the identifier of a signal in a Signal Verification."@en .


pko:stepNumber rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the number or index of a Step."@en ;
               skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the number or index of a Step."@en .


pko:toStatus rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the target status of a Change Of Status."@en ;
             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the target status of a Change Of Status."@en .


pko:toStep rdfs:comment "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the target step of a transition between steps."@en ;
           skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the target step of a transition between steps."@en .
