<https://w3id.org/pko> a owl:Ontology ;
    rdfs:label "Procedural Knowledge Ontology (PKO)" ;
    dcterms:contributor <https://orcid.org/0000-0001-5791-8427>,
        <https://orcid.org/0000-0001-9962-7193>,
        <https://orcid.org/0000-0002-9066-1229> ;
    dcterms:creator <https://orcid.org/0000-0002-8235-7331>,
        <https://orcid.org/0000-0003-1427-3723> ;
    dcterms:description "The Procedural Knowledge Ontology (PKO) addresses the Procedural Knowledge (PK) domain, and models procedures, their executions, and related resources and agents." ;
    dcterms:issued "2025-03-11" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-05-18" ;
    dcterms:publisher <https://ror.org/046bfkz44> ;
    dcterms:title "Procedural Knowledge Ontology (PKO)" ;
    bibo:status "Published Ontology"@en ;
    vann:preferredNamespacePrefix "pko" ;
    vann:preferredNamespaceUri "https://w3id.org/pko#" ;
    owl:priorVersion <https://w3id.org/pko/1.0.0> ;
    owl:versionIRI <https://w3id.org/pko/1.0.0> ;
    owl:versionInfo "2.0.0" ;
    schema:citation "Carriero, V.A., Scrocca, M., Baroni, I., Azzini, A., Celino, I. (2025). Procedural Knowledge Ontology (PKO)." ;
    schema:funding <https://doi.org/10.3030/101120323> ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

pko:Accepted a owl:NamedIndividual,
        pko:EvaluationRequestStatus .

pko:Approval a owl:NamedIndividual,
        pko:ProcedureStatus .

pko:Approved a owl:NamedIndividual,
        pko:ProcedureStatus .

pko:Archived a owl:NamedIndividual,
        pko:ProcedureStatus .

pko:Cancelled a owl:NamedIndividual,
        pko:ProcedureExecutionStatus .

pko:Completed a owl:NamedIndividual,
        pko:ProcedureExecutionStatus .

pko:Deprecated a owl:NamedIndividual,
        pko:ProcedureStatus .

pko:Draft a owl:NamedIndividual,
        pko:ProcedureStatus .

pko:Expert a owl:NamedIndividual,
        pko:ExpertiseLevel .

pko:Explanation a owl:Class ;
    rdfs:label "Explanation" .

pko:InProgress a owl:NamedIndividual,
        pko:ProcedureExecutionStatus .

pko:Junior a owl:NamedIndividual,
        pko:ExpertiseLevel .

pko:Master a owl:NamedIndividual,
        pko:ExpertiseLevel .

pko:NotEvaluated a owl:NamedIndividual,
        pko:RequirementSatisfactionLevel .

pko:NotSatisfied a owl:NamedIndividual,
        pko:RequirementSatisfactionLevel .

pko:PartiallySatisfied a owl:NamedIndividual,
        pko:RequirementSatisfactionLevel .

pko:Paused a owl:NamedIndividual,
        pko:ProcedureExecutionStatus .

pko:Pending a owl:NamedIndividual,
        pko:EvaluationRequestStatus .

pko:Qualification a owl:Class ;
    rdfs:label "Qualification" ;
    rdfs:subClassOf prov:Entity .

pko:Rejected a owl:NamedIndividual,
        pko:EvaluationRequestStatus .

pko:Satisfied a owl:NamedIndividual,
        pko:RequirementSatisfactionLevel .

pko:Senior a owl:NamedIndividual,
        pko:ExpertiseLevel .

pko:Validation a owl:NamedIndividual,
        pko:ProcedureStatus .

pko:addressesError a owl:ObjectProperty ;
    rdfs:label "addresses error" ;
    rdfs:domain pplan:Step ;
    rdfs:range pko:Error .

pko:answer a owl:DatatypeProperty ;
    rdfs:label "answer" ;
    rdfs:domain pko:FrequentlyAskedQuestion ;
    rdfs:range xsd:string .

pko:assigneeRole a owl:ObjectProperty ;
    rdfs:label "assignee role" ;
    rdfs:domain odrl:Rule ;
    rdfs:range pro:Role .

pko:changelogDescription a owl:DatatypeProperty ;
    rdfs:label "changelog description" ;
    rdfs:domain pko:Procedure ;
    rdfs:range xsd:string .

pko:errorCause a owl:DatatypeProperty ;
    rdfs:label "error cause" ;
    rdfs:domain pko:Error ;
    rdfs:range xsd:string .

pko:errorCode a owl:DatatypeProperty ;
    rdfs:label "error code" ;
    rdfs:domain pko:Error ;
    rdfs:range xsd:string .

pko:expectedSignalValue a owl:DatatypeProperty ;
    rdfs:label "expected signal value" ;
    rdfs:domain pko:SignalVerification ;
    rdfs:range xsd:string .

pko:feedbackOnProcedure a owl:DatatypeProperty ;
    rdfs:label "feedback on procedure" ;
    rdfs:domain pko:UserFeedbackOccurrence ;
    rdfs:range xsd:string .

pko:feedbackOnProcedureExecution a owl:DatatypeProperty ;
    rdfs:label "feedback on procedure execution" ;
    rdfs:domain pko:UserFeedbackOccurrence ;
    rdfs:range xsd:string .

pko:fromStatus a owl:ObjectProperty ;
    rdfs:label "from status" ;
    rdfs:domain pko:ChangeOfStatus ;
    rdfs:range pko:Status .

pko:fromStep a owl:ObjectProperty ;
    rdfs:label "from step" ;
    rdfs:domain pko:Transition ;
    rdfs:range pplan:Step .

pko:hasChangeOfStatus a owl:ObjectProperty ;
    rdfs:label "has change of status" ;
    rdfs:domain owl:Thing ;
    rdfs:range pko:ChangeOfStatus .

pko:hasEncounteredError a owl:ObjectProperty ;
    rdfs:label "has encountered error" ;
    rdfs:domain pko:IssueOccurrence ;
    rdfs:range pko:Error .

pko:hasExecutedProcedure a owl:ObjectProperty ;
    rdfs:label "has executed procedure" ;
    rdfs:domain pko:ProcedureExecution ;
    rdfs:range pko:Procedure .

pko:hasExecutedStep a owl:ObjectProperty ;
    rdfs:label "has executed step" ;
    rdfs:domain pko:StepExecution ;
    rdfs:range pplan:Step ;
    rdfs:subPropertyOf pplan:correspondsToStep .

pko:hasExpectedDuration a owl:ObjectProperty ;
    rdfs:label "has expected duration" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( pplan:Step pko:Procedure ) ] ;
    rdfs:range time:Duration .

pko:hasExplanation a owl:ObjectProperty ;
    rdfs:label "has explanation" .

pko:hasFAQCategory a owl:ObjectProperty ;
    rdfs:label "has f a q category" ;
    rdfs:domain pko:FrequentlyAskedQuestion ;
    rdfs:range pko:FAQCategory .

pko:hasFAQTarget a owl:ObjectProperty ;
    rdfs:label "has f a q target" ;
    rdfs:domain pko:FrequentlyAskedQuestion ;
    rdfs:range pko:FAQTarget .

pko:hasFallbackStep a owl:ObjectProperty ;
    rdfs:label "has fallback step" ;
    rdfs:domain pko:Procedure ;
    rdfs:range pplan:Step .

pko:hasFirstStep a owl:ObjectProperty ;
    rdfs:label "has first step" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( pko:Procedure pplan:MultiStep ) ] ;
    rdfs:range pplan:Step .

pko:hasIssueOccurrence a owl:ObjectProperty ;
    rdfs:label "has issue occurrence" ;
    rdfs:domain prov:Activity ;
    rdfs:range pko:IssueOccurrence .

pko:hasProcedureTarget a owl:ObjectProperty ;
    rdfs:label "has procedure target" ;
    rdfs:domain pko:Procedure ;
    rdfs:range owl:Thing .

pko:hasProcedureType a owl:ObjectProperty ;
    rdfs:label "has procedure type" ;
    rdfs:domain pko:Procedure ;
    rdfs:range pko:ProcedureType .

pko:hasRequirement a owl:ObjectProperty ;
    rdfs:label "has requirement" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( pplan:Step pko:Procedure pko:Transition ) ] .

pko:hasRequirementSatisfaction a owl:ObjectProperty ;
    rdfs:label "has requirement satisfaction" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( pplan:StepExecution pko:ProcedureExecution ) ] .

pko:hasRequirementSatisfactionLevel a owl:ObjectProperty ;
    rdfs:label "has requirement satisfaction level" ;
    rdfs:domain pko:RequirementSatisfaction ;
    rdfs:range pko:RequirementSatisfactionLevel .

pko:hasRequirementType a owl:ObjectProperty ;
    rdfs:label "has requirement type" ;
    rdfs:domain pko:Requirement ;
    rdfs:range pko:RequirementType .

pko:hasStep a owl:ObjectProperty ;
    rdfs:label "has step" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( pko:Procedure pplan:MultiStep ) ] ;
    rdfs:range pplan:Step .

pko:hasStepVerification a owl:ObjectProperty ;
    rdfs:label "has step verification" ;
    rdfs:domain pplan:Step ;
    rdfs:range pko:StepVerification .

pko:hasTemplate a owl:ObjectProperty ;
    rdfs:label "has template" ;
    rdfs:domain pko:Procedure ;
    rdfs:range pko:Procedure .

pko:hasUserFeedbackOccurrence a owl:ObjectProperty ;
    rdfs:label "has user feedback occurrence" ;
    rdfs:domain prov:Activity ;
    rdfs:range pko:UserFeedbackOccurrence .

pko:hasUserQuestionOccurrence a owl:ObjectProperty ;
    rdfs:label "has user question occurrence" ;
    rdfs:domain prov:Activity ;
    rdfs:range pko:UserQuestionOccurrence .

pko:includesStepExecution a owl:ObjectProperty ;
    rdfs:label "includes step execution" ;
    rdfs:domain pko:ProcedureExecution ;
    rdfs:range pko:StepExecution .

pko:isAdoptedBy a owl:ObjectProperty ;
    rdfs:label "is adopted by" ;
    rdfs:domain pko:Procedure .

pko:isChangeOfStatusOf a owl:ObjectProperty ;
    rdfs:label "is change of status of" ;
    rdfs:domain pko:ChangeOfStatus ;
    rdfs:range owl:Thing .

pko:isCurrentVersionOf a owl:ObjectProperty ;
    rdfs:label "is current version of" ;
    rdfs:domain pko:Procedure ;
    rdfs:range pko:Procedure .

pko:isFirstStepOf a owl:ObjectProperty ;
    rdfs:label "is first step of" ;
    rdfs:domain pplan:Step ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( pko:Procedure pplan:MultiStep ) ],
        pko:Procedure .

pko:isIncludedInProcedureExecution a owl:ObjectProperty ;
    rdfs:label "is included in procedure execution" ;
    rdfs:domain pko:StepExecution ;
    rdfs:range pko:ProcedureExecution .

