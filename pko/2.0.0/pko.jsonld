  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the source step of a transition between steps."
