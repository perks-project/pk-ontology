  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "url"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the URL associated with a Resource."
  } ]
}, {
  "@id" : "https://w3id.org/force/sotw#EvaluationRequest",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Evaluation Request"
  } ]
}, {
  "@id" : "https://w3id.org/force/sotw#evaluatedAction",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/dcam/domainIncludes" : [ {
    "@id" : "https://w3id.org/force/sotw#EvaluationRequest"
  } ],
  "http://purl.org/dc/dcam/rangeIncludes" : [ {
    "@id" : "http://www.w3.org/ns/odrl/2/Action"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "evaluated action"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an evaluation request to the action being evaluated."
  } ]
}, {
  "@id" : "https://w3id.org/force/sotw#evaluatedTarget",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/dcam/domainIncludes" : [ {
    "@id" : "https://w3id.org/force/sotw#EvaluationRequest"
  } ],
  "http://purl.org/dc/dcam/rangeIncludes" : [ {
    "@id" : "https://w3id.org/pko#Procedure"
  }, {
    "@id" : "https://w3id.org/pko#ProcedureType"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "evaluated target"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link an evaluation request to the target resource for which the action is evaluated, e.g. a Procedure or a Procedure Type."
  } ]
}, {
  "@id" : "https://w3id.org/mod#createdWith",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/pko",
