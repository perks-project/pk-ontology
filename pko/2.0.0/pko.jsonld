    "@value" : "error cause"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the cause of an Error that can be encountered during the Procedure or Step Execution."
  } ]
}, {
  "@id" : "https://w3id.org/pko#errorCode",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the code of an Error that can be encountered during the Procedure or Step Execution."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/pko#Error"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "error code"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the code of an Error that can be encountered during the Procedure or Step Execution."
  } ]
}, {
  "@id" : "https://w3id.org/pko#expectedSignalValue",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
