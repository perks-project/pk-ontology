  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/pko#Status"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the starting status of a Change Of Status."
  } ]
